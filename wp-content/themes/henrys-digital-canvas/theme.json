{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "760px",
			"wideSize": "1400px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{ "slug": "background", "name": "Background", "color": "hsl(var(--wpds-color-surface-canvas))" },
				{ "slug": "foreground", "name": "Foreground", "color": "hsl(var(--wpds-color-text-primary))" },
				{ "slug": "primary", "name": "Primary", "color": "hsl(var(--wpds-color-accent))" },
				{ "slug": "secondary", "name": "Secondary", "color": "hsl(var(--wpds-color-surface-subtle))" },
				{ "slug": "accent", "name": "Accent", "color": "hsl(var(--wpds-color-accent-strong))" },
				{ "slug": "link", "name": "Link", "color": "hsl(var(--wpds-color-link))" },
				{ "slug": "link-hover", "name": "Link Hover", "color": "hsl(var(--wpds-color-link-hover))" },
				{ "slug": "muted", "name": "Muted", "color": "hsl(var(--wpds-color-surface-muted))" },
				{ "slug": "card", "name": "Card", "color": "hsl(var(--wpds-color-surface-card))" },
				{ "slug": "border", "name": "Border", "color": "hsl(var(--wpds-color-border-subtle))" },
				{ "slug": "success", "name": "Success", "color": "hsl(var(--wpds-color-success))" },
				{ "slug": "warning", "name": "Warning", "color": "hsl(var(--wpds-color-warning))" },
				{ "slug": "info", "name": "Info", "color": "hsl(var(--wpds-color-info))" },
				{ "slug": "destructive", "name": "Destructive", "color": "hsl(var(--wpds-color-destructive))" }
			],
			"gradients": [
				{
					"slug": "surface-hero",
					"name": "Surface Hero",
					"gradient": "linear-gradient(135deg, hsl(var(--wpds-color-accent-strong) / 0.14) 0%, transparent 50%)"
				},
				{
					"slug": "surface-card",
					"name": "Surface Card",
					"gradient": "linear-gradient(145deg, hsl(var(--wpds-color-surface-card)) 0%, hsl(var(--wpds-color-surface-muted)) 100%)"
				},
				{
					"slug": "surface-emphasis",
					"name": "Surface Emphasis",
					"gradient": "linear-gradient(135deg, hsl(var(--wpds-color-accent-strong)) 0%, hsl(28 85% 55%) 100%)"
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": [ "px", "rem", "em", "%", "vh", "vw" ],
			"spacingSizes": [
				{ "slug": "2xs", "name": "2XS", "size": "0.25rem" },
				{ "slug": "xs", "name": "XS", "size": "0.5rem" },
				{ "slug": "sm", "name": "SM", "size": "0.75rem" },
				{ "slug": "md", "name": "MD", "size": "1rem" },
				{ "slug": "lg", "name": "LG", "size": "1.5rem" },
				{ "slug": "xl", "name": "XL", "size": "2rem" },
				{ "slug": "2xl", "name": "2XL", "size": "3rem" }
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"slug": "source-serif-4",
					"name": "Source Serif 4",
					"fontFamily": "\"Source Serif 4\", Georgia, serif"
				},
				{
					"slug": "playfair-display",
					"name": "Playfair Display",
					"fontFamily": "\"Playfair Display\", Georgia, serif"
				},
				{
					"slug": "jetbrains-mono",
					"name": "JetBrains Mono",
					"fontFamily": "\"JetBrains Mono\", monospace"
				}
			],
			"fontSizes": [
				{ "slug": "xs", "name": "XS", "size": "0.75rem" },
				{ "slug": "sm", "name": "SM", "size": "0.875rem" },
				{ "slug": "md", "name": "MD", "size": "1rem" },
				{ "slug": "lg", "name": "LG", "size": "1.25rem" },
				{ "slug": "xl", "name": "XL", "size": "1.75rem" },
				{ "slug": "2xl", "name": "2XL", "size": "2.25rem" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "hsl(var(--wpds-color-surface-canvas))",
			"text": "hsl(var(--wpds-color-text-primary))"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--md)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--md)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--md)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--source-serif-4)",
			"fontSize": "var(--wp--preset--font-size--md)",
			"fontWeight": "400",
			"letterSpacing": "normal",
			"lineHeight": "1.65"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "hsl(var(--wpds-color-text-primary))"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--playfair-display)",
					"fontWeight": "600",
					"letterSpacing": "-0.01em",
					"lineHeight": "1.2"
				}
			},
			"link": {
				"color": {
					"text": "hsl(var(--wpds-color-link))"
				},
				":hover": {
					"color": {
						"text": "hsl(var(--wpds-color-link-hover))"
					}
				}
			},
			"button": {
				"border": {
					"radius": "var(--radius-control)"
				},
				"color": {
					"background": "hsl(var(--wpds-color-accent))",
					"text": "hsl(var(--wpds-color-accent-foreground))"
				},
				"spacing": {
					"padding": {
						"top": "0.65rem",
						"right": "1rem",
						"bottom": "0.65rem",
						"left": "1rem"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--source-serif-4)",
					"fontSize": "0.95rem",
					"fontWeight": "600",
					"lineHeight": "1.2"
				},
				":hover": {
					"color": {
						"background": "hsl(var(--wpds-color-accent-strong))",
						"text": "hsl(var(--wpds-color-accent-foreground))"
					}
				},
				":focus": {
					"outline": {
						"color": "hsl(var(--wpds-color-focus-ring))",
						"offset": "var(--focus-ring-offset)",
						"width": "var(--focus-ring-width)",
						"style": "solid"
					}
				}
			},
			"caption": {
				"color": {
					"text": "hsl(var(--wpds-color-text-muted))"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"lineHeight": "1.4"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2xl)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--lg)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--md)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"letterSpacing": "0.02em"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xs)",
					"fontWeight": "600",
					"letterSpacing": "0.05em",
					"textTransform": "uppercase"
				}
			}
		},
		"blocks": {
			"core/avatar": {
				"border": {
					"radius": "var(--radius-pill)"
				}
			},
			"core/button": {
				"color": {
					"background": "hsl(var(--wpds-color-accent))",
					"text": "hsl(var(--wpds-color-accent-foreground))"
				},
				"border": {
					"radius": "var(--radius-control)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--source-serif-4)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "600",
					"lineHeight": "1.2"
				},
				"spacing": {
					"padding": {
						"top": "0.65rem",
						"right": "1rem",
						"bottom": "0.65rem",
						"left": "1rem"
					}
				},
				"variations": {
					"outline": {
						"border": {
							"width": "1px",
							"style": "solid",
							"color": "hsl(var(--wpds-color-border-subtle))",
							"radius": "var(--radius-control)"
						},
						"color": {
							"background": "transparent",
							"text": "hsl(var(--wpds-color-text-primary))"
						},
						"spacing": {
							"padding": {
								"top": "calc(0.65rem - 1px)",
								"right": "calc(1rem - 1px)",
								"bottom": "calc(0.65rem - 1px)",
								"left": "calc(1rem - 1px)"
							}
						},
						"css": ".wp-block-button__link:not(.has-background):hover { background-color: hsl(var(--secondary)); }"
					}
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--sm)"
				}
			},
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				},
				"color": {
					"background": "hsl(var(--muted))",
					"text": "hsl(var(--foreground))"
				},
				"border": {
					"radius": "var(--radius-control)"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--xs)",
						"right": "var(--wp--preset--spacing--sm)",
						"bottom": "var(--wp--preset--spacing--xs)",
						"left": "var(--wp--preset--spacing--sm)"
					}
				}
			},
			"core/column": {
				"variations": {
					"section-1": {
						"color": { "background": "hsl(var(--muted))", "text": "hsl(var(--foreground))" }
					},
					"section-2": {
						"color": { "background": "hsl(var(--secondary))", "text": "hsl(var(--foreground))" }
					},
					"section-3": {
						"color": { "background": "hsl(var(--primary))", "text": "hsl(var(--primary-foreground))" }
					},
					"section-4": {
						"color": { "background": "hsl(var(--card))", "text": "hsl(var(--foreground))" },
						"elements": {
							"button": {
								"color": {
									"background": "hsl(var(--secondary))",
									"text": "hsl(var(--foreground))"
								},
								":hover": {
									"color": {
										"background": "hsl(var(--muted))",
										"text": "hsl(var(--foreground))"
									}
								}
							}
						}
					},
					"section-5": {
						"color": { "background": "hsl(var(--foreground))", "text": "hsl(var(--background))" },
						"elements": {
							"button": {
								"color": {
									"background": "hsl(var(--background))",
									"text": "hsl(var(--foreground))"
								},
								":hover": {
									"color": {
										"background": "hsl(var(--secondary))",
										"text": "hsl(var(--foreground))"
									}
								}
							}
						}
					}
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--lg)"
				},
				"variations": {
					"section-1": {
						"color": { "background": "hsl(var(--muted))", "text": "hsl(var(--foreground))" }
					},
					"section-2": {
						"color": { "background": "hsl(var(--secondary))", "text": "hsl(var(--foreground))" }
					},
					"section-3": {
						"color": { "background": "hsl(var(--primary))", "text": "hsl(var(--primary-foreground))" }
					},
					"section-4": {
						"color": { "background": "hsl(var(--card))", "text": "hsl(var(--foreground))" },
						"elements": {
							"button": {
								"color": {
									"background": "hsl(var(--secondary))",
									"text": "hsl(var(--foreground))"
								},
								":hover": {
									"color": {
										"background": "hsl(var(--muted))",
										"text": "hsl(var(--foreground))"
									}
								}
							}
						}
					},
					"section-5": {
						"color": { "background": "hsl(var(--foreground))", "text": "hsl(var(--background))" },
						"elements": {
							"button": {
								"color": {
									"background": "hsl(var(--background))",
									"text": "hsl(var(--foreground))"
								},
								":hover": {
									"color": {
										"background": "hsl(var(--secondary))",
										"text": "hsl(var(--foreground))"
									}
								}
							}
						}
					}
				}
			},
			"core/comment-author-name": {
				"color": {
					"text": "hsl(var(--text-meta))"
				},
				"elements": {
					"link": {
						"color": {
							"text": "hsl(var(--text-meta))"
						},
						":hover": {
							"color": {
								"text": "hsl(var(--link-hover))"
							}
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xs)",
					"fontWeight": "500"
				}
			},
			"core/comment-content": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--md)",
					"lineHeight": "1.65"
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--sm)",
						"bottom": "var(--wp--preset--spacing--sm)"
					}
				}
			},
			"core/comment-date": {
				"color": {
					"text": "hsl(var(--text-subtle))"
				},
				"elements": {
					"link": {
						"color": {
							"text": "hsl(var(--text-subtle))"
						},
						":hover": {
							"color": {
								"text": "hsl(var(--link-hover))"
							}
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xs)"
				}
			},
			"core/comment-edit-link": {
				"elements": {
					"link": {
						"color": {
							"text": "hsl(var(--link))"
						},
						":hover": {
							"color": {
								"text": "hsl(var(--link-hover))"
							}
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xs)"
				}
			},
			"core/comment-reply-link": {
				"elements": {
					"link": {
						"color": {
							"text": "hsl(var(--link))"
						},
						":hover": {
							"color": {
								"text": "hsl(var(--link-hover))"
							}
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xs)"
				}
			},
			"core/comments-pagination": {
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--md)",
						"bottom": "var(--wp--preset--spacing--md)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				}
			},
			"core/comments-pagination-next": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				}
			},
			"core/comments-pagination-numbers": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				}
			},
			"core/comments-pagination-previous": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				}
			},
			"core/group": {
				"border": {
					"radius": "var(--radius-surface)"
				},
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--md)"
				},
				"variations": {
					"section-1": {
						"color": { "background": "hsl(var(--muted))", "text": "hsl(var(--foreground))" }
					},
					"section-2": {
						"color": { "background": "hsl(var(--secondary))", "text": "hsl(var(--foreground))" }
					},
					"section-3": {
						"color": { "background": "hsl(var(--primary))", "text": "hsl(var(--primary-foreground))" }
					},
					"section-4": {
						"color": { "background": "hsl(var(--card))", "text": "hsl(var(--foreground))" },
						"elements": {
							"button": {
								"color": {
									"background": "hsl(var(--secondary))",
									"text": "hsl(var(--foreground))"
								},
								":hover": {
									"color": {
										"background": "hsl(var(--muted))",
										"text": "hsl(var(--foreground))"
									}
								}
							}
						}
					},
					"section-5": {
						"color": { "background": "hsl(var(--foreground))", "text": "hsl(var(--background))" },
						"elements": {
							"button": {
								"color": {
									"background": "hsl(var(--background))",
									"text": "hsl(var(--foreground))"
								},
								":hover": {
									"color": {
										"background": "hsl(var(--secondary))",
										"text": "hsl(var(--foreground))"
									}
								}
							}
						}
					}
				}
			},
			"core/heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--playfair-display)",
					"lineHeight": "1.2",
					"fontWeight": "600",
					"letterSpacing": "-0.01em"
				},
				"color": {
					"text": "hsl(var(--text-strong))"
				},
				"variations": {
					"text-display": {
						"typography": {
							"fontFamily": "var(--wp--preset--font-family--playfair-display)",
							"fontSize": "clamp(2.2rem, 2.2rem + ((1vw - 0.2rem) * 1.333), 3.5rem)",
							"lineHeight": "1.1"
						}
					},
					"text-subtitle": {
						"typography": {
							"fontFamily": "var(--wp--preset--font-family--playfair-display)",
							"fontSize": "clamp(1.5rem, 1.5rem + ((1vw - 0.2rem) * 0.392), 1.75rem)",
							"lineHeight": "1.2"
						}
					},
					"text-annotation": {
						"css": "width: fit-content",
						"typography": {
							"fontFamily": "var(--wp--preset--font-family--source-serif-4)",
							"fontSize": "var(--wp--preset--font-size--xs)",
							"lineHeight": "1.5",
							"letterSpacing": "normal"
						},
						"color": {
							"text": "hsl(var(--text-subtle))"
						},
						"border": {
							"color": "hsl(var(--border))",
							"style": "solid",
							"width": "1px",
							"radius": "9999px"
						},
						"spacing": {
							"padding": {
								"top": "0.2rem",
								"right": "0.6rem",
								"bottom": "0.25rem",
								"left": "0.6rem"
							}
						},
						"elements": {
							"link": {
								"typography": {
									"textDecoration": "none"
								}
							}
						}
					}
				}
			},
			"core/icon": {
				"dimensions": {
					"width": "24px"
				},
				"color": {
					"text": "hsl(var(--link))"
				}
			},
			"core/list": {
				"color": {
					"text": "hsl(var(--text-body))"
				},
				"css": "& li{margin-top: 0.5rem; line-height: 1.6;}"
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				},
				"elements": {
					"link": {
						"color": {
							"text": "hsl(var(--foreground))"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "hsl(var(--link-hover))"
							},
							"typography": {
								"textDecoration": "none"
							}
						}
					}
				}
			},
			"core/paragraph": {
				"color": {
					"text": "hsl(var(--text-body))"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--md)",
					"lineHeight": "1.65"
				},
				"variations": {
					"text-display": {
						"typography": {
							"fontFamily": "var(--wp--preset--font-family--playfair-display)",
