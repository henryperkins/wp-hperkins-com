{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "henrys-digital-canvas/about-timeline",
	"title": "About Timeline",
	"category": "widgets",
	"icon": "id",
	"description": "About page profile, values, and timeline migration block.",
	"textdomain": "henrys-digital-canvas",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": "About Henry Perkins"
		},
		"showValues": {
			"type": "boolean",
			"default": true
		},
		"showTimeline": {
			"type": "boolean",
			"default": true
		}
	},
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
