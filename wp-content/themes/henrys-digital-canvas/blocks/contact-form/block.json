{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "henrys-digital-canvas/contact-form",
	"title": "Contact Form",
	"category": "widgets",
	"icon": "email-alt",
	"description": "Contact form with client validation and submit lifecycle parity.",
	"textdomain": "henrys-digital-canvas",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Contact"
		},
		"description": {
			"type": "string",
			"default": "Open to US remote opportunities and consulting engagements. Reach out if you want help with customer-facing technical workflows, web delivery, or AI integrations."
		},
		"showSocialLinks": {
			"type": "boolean",
			"default": true
		},
		"submitLabel": {
			"type": "string",
			"default": "Send Message"
		},
		"submittingLabel": {
			"type": "string",
			"default": "Sending…"
		}
	},
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
