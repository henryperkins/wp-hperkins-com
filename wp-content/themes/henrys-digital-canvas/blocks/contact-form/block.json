{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "henrys-digital-canvas/contact-form",
	"title": "Contact Form",
	"category": "widgets",
	"icon": "email-alt",
	"description": "Contact form with client validation and submit lifecycle parity.",
	"textdomain": "henrys-digital-canvas",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Contact",
			"role": "content"
		},
		"description": {
			"type": "string",
			"default": "Open to US remote opportunities and consulting engagements. Reach out if you want help with customer-facing technical workflows, web delivery, or AI integrations.",
			"role": "content"
		},
		"showSocialLinks": {
			"type": "boolean",
			"default": true
		},
		"submitLabel": {
			"type": "string",
			"default": "Send Message",
			"role": "content"
		},
		"submittingLabel": {
			"type": "string",
			"default": "Sending…",
			"role": "content"
		}
	},
	"editorScript": "file:./build/index.js",
	"viewScript": "file:./build/view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
