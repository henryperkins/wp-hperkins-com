{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "henrys-digital-canvas/resume-ats",
	"title": "Resume ATS",
	"category": "widgets",
	"icon": "media-document",
	"description": "ATS-focused one-page resume layout sourced from theme data contracts.",
	"textdomain": "henrys-digital-canvas",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": "ATS One-Page Resume"
		},
		"showPrintButton": {
			"type": "boolean",
			"default": true
		},
		"showBackLink": {
			"type": "boolean",
			"default": true
		}
	},
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
