{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "henrys-digital-canvas/blog-index",
	"title": "Blog Index",
	"category": "widgets",
	"icon": "welcome-write-blog",
	"description": "Blog listing with featured post hero, search, tag filters, and newsletter CTA.",
	"textdomain": "henrys-digital-canvas",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Blog"
		},
		"description": {
			"type": "string",
			"default": "Notes on engineering systems, product craft, and learning in public."
		},
		"showNewsletterCta": {
			"type": "boolean",
			"default": true
		}
	},
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
