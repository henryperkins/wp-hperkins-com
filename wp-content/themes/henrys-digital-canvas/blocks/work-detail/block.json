{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "henrys-digital-canvas/work-detail",
	"title": "Work Detail",
	"category": "widgets",
	"icon": "portfolio",
	"description": "Project detail view for /work/{repo} case-study routes.",
	"textdomain": "henrys-digital-canvas",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"attributes": {
		"repo": {
			"type": "string",
			"default": ""
		},
		"showBackLink": {
			"type": "boolean",
			"default": true
		},
		"showWhenMissingRepo": {
			"type": "boolean",
			"default": false
		}
	},
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
