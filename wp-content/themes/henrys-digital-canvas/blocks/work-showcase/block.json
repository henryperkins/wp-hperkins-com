{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "henrys-digital-canvas/work-showcase",
	"title": "Work Showcase",
	"category": "widgets",
	"icon": "portfolio",
	"description": "React-powered work showcase with GitHub sync, fallback data, compare sheet, and timeline/grid views.",
	"textdomain": "henrys-digital-canvas",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Work"
		},
		"description": {
			"type": "string",
			"default": "A mix of public GitHub repositories and private case studies with compare and filter controls."
		},
		"githubUsername": {
			"type": "string",
			"default": "henryperkins"
		},
		"repoCount": {
			"type": "number",
			"default": 100
		},
		"compareLimit": {
			"type": "number",
			"default": 2
		},
		"includeForks": {
			"type": "boolean",
			"default": false
		},
		"includeArchived": {
			"type": "boolean",
			"default": false
		},
		"openInNewTab": {
			"type": "boolean",
			"default": true
		},
		"showSignalsPanel": {
			"type": "boolean",
			"default": true
		},
		"showActivitySparkline": {
			"type": "boolean",
			"default": true
		},
		"sparklineWeeks": {
			"type": "number",
			"default": 8
		},
		"githubProxyUrl": {
			"type": "string",
			"default": "/api/github/repos"
		},
		"githubLanguageSummaryProxyUrl": {
			"type": "string",
			"default": "/api/github/language-summary"
		},
		"languageSummaryMaxRepos": {
			"type": "number",
			"default": 120
		}
	},
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
