{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "henrys-digital-canvas/digital-canvas-feed",
	"title": "Digital Canvas Feed",
	"category": "widgets",
	"icon": "screenoptions",
	"description": "React-powered block showing featured work and recent writing from theme data contracts.",
	"textdomain": "henrys-digital-canvas",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Featured Work and Recent Writing",
			"role": "content"
		},
		"showBlog": {
			"type": "boolean",
			"default": true
		},
		"showRepos": {
			"type": "boolean",
			"default": true
		},
		"blogCount": {
			"type": "number",
			"default": 3
		},
		"repoCount": {
			"type": "number",
			"default": 3
		},
		"postsEndpoint": {
			"type": "string",
			"default": ""
		},
		"openInNewTab": {
			"type": "boolean",
			"default": false
		}
	},
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
